{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_USE_MOCK_API": "true",
        "EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN": "YOUR_MAPBOX_SECRET_TOKEN"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
