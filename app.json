{
  "expo": {
    "name": "TrailSense",
    "slug": "trailsense",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.trailsense.app",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "TrailSense needs your location to enable geofencing and device location tracking.",
        "NSCameraUsageDescription": "TrailSense needs camera access to scan device QR codes.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.trailsense.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-location",
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsDownloadToken": "",
          "RNMapboxMapsVersion": "11.15.2"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "d0479bb6-2ae8-4343-b29a-980e099b58c2"
      },
      "router": {}
    },
    "owner": "cdschexnide"
  }
}
